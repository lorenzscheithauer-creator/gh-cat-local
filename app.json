    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#031733"
      },
      "package": "de.gewinnhai.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
