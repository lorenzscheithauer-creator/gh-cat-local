{
  "expo": {
    "name": "GewinnHai",
    "slug": "gewinnhai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/branding/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#031733"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
